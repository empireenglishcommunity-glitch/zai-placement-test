# ═══════════════════════════════════════════════════════════
# EMPIRE ENGLISH COMMUNITY — Environment Variables
# Z.ai Placement Test Deployment
# ═══════════════════════════════════════════════════════════

# ─── Database (Prisma) ──────────────────────────────────────
# SQLite for local dev, PostgreSQL for production
DATABASE_URL=file:./db/custom.db
# For production (e.g., Supabase):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ─── Authentication (NextAuth.js) ──────────────────────────
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000
# For production:
# NEXTAUTH_URL=https://assessment.empireenglish.online

# ─── AI Services (Gemini) ──────────────────────────────────
# Used for: speaking evaluation, listening passage generation
# Free tier: 1000 requests/day
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Email (Nodemailer) ────────────────────────────────────
# Used for: sending assessment results to students/admin
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=admin@empireenglish.online
