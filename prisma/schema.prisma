// ═══════════════════════════════════════════════════════════
// EMPIRE ENGLISH COMMUNITY — Prisma Schema
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Profiles ──────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  displayName  String?
  avatarUrl    String?
  isAdmin      Boolean   @default(false)
  emailVerified Boolean  @default(false)
  verifyToken   String?
  verifyTokenExpiry DateTime?
  resetToken    String?
  resetTokenExpiry DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      Profile?
  assessments  Assessment[]
  recordings   Recording[]
  reviewFlags  ReviewFlag[]
  adminNotes   AdminNote[] @relation("AdminNotesByTarget")
  notesAuthored AdminNote[] @relation("AdminNotesByAuthor")

  @@map("users")
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  currentLevel    Int      @default(0)
  assessmentCount Int      @default(0)
  streak          Int      @default(0)
  termsAccepted   Boolean  @default(false)
  termsAcceptedAt DateTime?
  lastActiveAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Assessment System ─────────────────────────────────────

model Assessment {
  id            String   @id @default(cuid())
  userId        String
  status        String   @default("not_started")  // not_started, in_progress, completed
  currentModule String?   // speaking, listening, vocabulary, grammar
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  // Speaking scores
  spPronunciation  Float?
  spFluency        Float?
  spWordsPerMinute Float?
  spPhonemeAcc     Float?
  spGrammarAcc     Float?
  spVocabRange     Float?
  spConfidence     Float?
  spRhythmMatch    Float?
  spOverall        Float?
  spLevel          Int?

  // Listening scores
  liLiteral  Float?
  liInference Float?
  liDetail   Float?
  liOverall  Float?
  liLevel    Int?

  // Vocabulary scores
  voBand1 Float?
  voBand2 Float?
  voBand3 Float?
  voBand4 Float?
  voBand5 Float?
  voEstimatedSize Float?
  voOverall Float?
  voLevel  Int?

  // Grammar scores
  grPercentage Float?
  grLevel      Int?

  // TOEFL Section Scores (0-30 each, new format)
  readingScore   Float?   // 0-30
  listeningScore Float?   // 0-30
  speakingScore  Float?   // 0-30
  writingScore   Float?   // 0-30
  totalScore     Float?   // 0-120
  cefrLevel      String?  // A1, A2-B1, B1-B2, C1-C2

  // Final result
  assignedLevel Int?
  flagged       Boolean  @default(false)
  flagReason    String?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordings Recording[]
  answers   Answer[]

  @@index([userId])
  @@index([status])
  @@map("assessments")
}

// ─── Recordings ────────────────────────────────────────────

model Recording {
  id           String   @id @default(cuid())
  assessmentId String
  userId       String
  module       String   // speaking_read, speaking_spontaneous, speaking_shadow, listening
  part         String?  // A, B, C
  audioUrl     String
  duration     Float?
  transcript   String?
  createdAt    DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("recordings")
}

// ─── Answers ───────────────────────────────────────────────

model Answer {
  id           String   @id @default(cuid())
  assessmentId String
  module       String   // vocabulary, grammar, listening
  questionId   String
  selectedAnswer Int?
  isCorrect    Boolean?
  timeTaken    Int?     // milliseconds
  createdAt    DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([module])
  @@map("answers")
}

// ─── Questions Bank ────────────────────────────────────────

model Question {
  id             String   @id @default(cuid())
  module         String   // vocabulary, grammar, listening
  type           String?  // completion, error_identification, transformation, literal, inference, detail
  topic          String?  // grammar topic or vocab band
  questionText   String
  options        String   // JSON array
  correctAnswer  Int
  difficulty     Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([module])
  @@index([topic])
  @@index([isActive])
  @@map("questions")
}

// ─── Admin & Review ────────────────────────────────────────

model ReviewFlag {
  id          String    @id @default(cuid())
  userId      String
  assessmentId String
  reason      String
  reviewedBy  String?
  reviewedAt  DateTime?
  resolved    Boolean   @default(false)
  notes       String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resolved])
  @@index([userId])
  @@map("review_flags")
}

model AdminNote {
  id          String   @id @default(cuid())
  adminId     String
  targetUserId String
  content     String
  createdAt   DateTime @default(now())

  admin       User @relation("AdminNotesByAuthor", fields: [adminId], references: [id])
  targetUser  User @relation("AdminNotesByTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@map("admin_notes")
}

// ─── Assessment Sessions (Anti-Cheat: Locked Question Sets) ──

model AssessmentSession {
  id            String   @id @default(cuid())
  userId        String
  module        String   // vocabulary, grammar
  attemptNumber Int      @default(1)
  questionSet   String   // JSON array of question IDs in order, locked per session
  optionMapping String   // JSON: { questionId: [shuffled option indices] } for answer remapping
  seed          Int      // Random seed used for this session (deterministic)
  status        String   @default("active") // active, completed, abandoned
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  @@index([userId, module])
  @@index([status])
  @@map("assessment_sessions")
}

model QuestionExposure {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  module     String
  attemptNum Int      // which attempt this question was shown in
  shownAt    DateTime @default(now())

  @@unique([userId, questionId, attemptNum])
  @@index([userId, module])
  @@index([userId, questionId])
  @@map("question_exposures")
}

// ─── Invite Codes ────────────────────────────────────────────

model InviteCode {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("general") // general, paid, free, vip
  maxUses     Int      @default(1)  // -1 = unlimited
  usedCount   Int      @default(0)
  usedBy      String?  // JSON array of user IDs who used it
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  note        String?  // admin note (e.g., "For Discord batch June 2026")

  @@index([code])
  @@index([isActive])
  @@map("invite_codes")
}

// ─── IP & Ownership Records ──────────────────────────────────

model OwnershipRecord {
  id          String   @id @default(cuid())
  eventType   String   // terms_acceptance, content_publication, certificate_generation, system_update, ownership_declaration
  description String
  metadata    String?  // JSON string for additional data
  userId      String?  // Optional: link to user if applicable
  createdBy   String?  // admin or system
  createdAt   DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
  @@map("ownership_records")
}
