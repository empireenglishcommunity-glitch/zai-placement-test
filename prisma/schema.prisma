// ═══════════════════════════════════════════════════════════
// EMPIRE ENGLISH COMMUNITY — Prisma Schema
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Profiles ──────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  displayName  String?
  avatarUrl    String?
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      Profile?
  assessments  Assessment[]
  recordings   Recording[]
  reviewFlags  ReviewFlag[]
  adminNotes   AdminNote[] @relation("AdminNotesByTarget")
  notesAuthored AdminNote[] @relation("AdminNotesByAuthor")

  @@map("users")
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  currentLevel    Int      @default(0)
  assessmentCount Int      @default(0)
  streak          Int      @default(0)
  termsAccepted   Boolean  @default(false)
  termsAcceptedAt DateTime?
  lastActiveAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Assessment System ─────────────────────────────────────

model Assessment {
  id            String   @id @default(cuid())
  userId        String
  status        String   @default("not_started")  // not_started, in_progress, completed
  currentModule String?   // speaking, listening, vocabulary, grammar
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  // Speaking scores
  spPronunciation  Float?
  spFluency        Float?
  spWordsPerMinute Float?
  spPhonemeAcc     Float?
  spGrammarAcc     Float?
  spVocabRange     Float?
  spConfidence     Float?
  spRhythmMatch    Float?
  spOverall        Float?
  spLevel          Int?

  // Listening scores
  liLiteral  Float?
  liInference Float?
  liDetail   Float?
  liOverall  Float?
  liLevel    Int?

  // Vocabulary scores
  voBand1 Float?
  voBand2 Float?
  voBand3 Float?
  voBand4 Float?
  voBand5 Float?
  voEstimatedSize Float?
  voOverall Float?
  voLevel  Int?

  // Grammar scores
  grPercentage Float?
  grLevel      Int?

  // Final result
  assignedLevel Int?
  flagged       Boolean  @default(false)
  flagReason    String?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordings Recording[]
  answers   Answer[]

  @@index([userId])
  @@index([status])
  @@map("assessments")
}

// ─── Recordings ────────────────────────────────────────────

model Recording {
  id           String   @id @default(cuid())
  assessmentId String
  userId       String
  module       String   // speaking_read, speaking_spontaneous, speaking_shadow, listening
  part         String?  // A, B, C
  audioUrl     String
  duration     Float?
  transcript   String?
  createdAt    DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("recordings")
}

// ─── Answers ───────────────────────────────────────────────

model Answer {
  id           String   @id @default(cuid())
  assessmentId String
  module       String   // vocabulary, grammar, listening
  questionId   String
  selectedAnswer Int?
  isCorrect    Boolean?
  timeTaken    Int?     // milliseconds
  createdAt    DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([module])
  @@map("answers")
}

// ─── Questions Bank ────────────────────────────────────────

model Question {
  id             String   @id @default(cuid())
  module         String   // vocabulary, grammar, listening
  type           String?  // completion, error_identification, transformation, literal, inference, detail
  topic          String?  // grammar topic or vocab band
  questionText   String
  options        String   // JSON array
  correctAnswer  Int
  difficulty     Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([module])
  @@index([topic])
  @@index([isActive])
  @@map("questions")
}

// ─── Admin & Review ────────────────────────────────────────

model ReviewFlag {
  id          String    @id @default(cuid())
  userId      String
  assessmentId String
  reason      String
  reviewedBy  String?
  reviewedAt  DateTime?
  resolved    Boolean   @default(false)
  notes       String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([resolved])
  @@index([userId])
  @@map("review_flags")
}

model AdminNote {
  id          String   @id @default(cuid())
  adminId     String
  targetUserId String
  content     String
  createdAt   DateTime @default(now())

  admin       User @relation("AdminNotesByAuthor", fields: [adminId], references: [id])
  targetUser  User @relation("AdminNotesByTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@map("admin_notes")
}
